# Copy this to .env and fill in your own values.
# .env is gitignored and must NEVER be committed.

# PostgreSQL password for the nakama DB user
POSTGRES_PASSWORD=change-me

# Nakama socket server key (clients use this to connect; must match VITE_NAKAMA_SERVER_KEY)
NAKAMA_SERVER_KEY=change-me-server-key

# Nakama admin console password  (http://localhost:7349)
NAKAMA_CONSOLE_PASSWORD=change-me-admin
